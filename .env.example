# Appwrite Configuration (para la app cliente)
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=697cf77a0038f25cd6e6
# Opcional: en web se usa window.location.hostname por defecto (debe coincidir con la plataforma en Appwrite)
# EXPO_PUBLIC_APPWRITE_PLATFORM=finaria.expo.app

# Appwrite Configuration (para scripts de Node.js - server-side)
# Dashboard → Settings → View API Keys → Create API Key
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=697cf77a0038f25cd6e6
APPWRITE_API_KEY=your_api_key_here
# Insforge Configuration
EXPO_PUBLIC_INSFORGE_URL=https://m4kkgsr8.us-east.insforge.app
EXPO_PUBLIC_INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Expo Token
EXPO_TOKEN=your_expo_token_here
